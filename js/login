<!DOCTYPE html>
<html lang="th">
<head>
    <base target="_top">
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>ระบบขอใช้และจองรถยนต์</title>
    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.1.1/css/all.min.css">
    
    <style>
    * {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
    }

    body {
        font-family: 'Prompt', 'Segoe UI', sans-serif;
        background: #2D1B69;
        color: #FFFFFF;
        min-height: 100vh;
        display: flex;
        align-items: center;
        justify-content: center;
    }

    #login-container {
        display: flex;
        width: 100%;
        height: 100vh;
        justify-content: center;
        align-items: center;
        position: relative;
    }

    .login-wrapper {
        position: relative;
        width: 100%;
        max-width: 450px;
        display: flex;
        flex-direction: column;
        align-items: center;
        padding: 20px;
    }

    .login-icon {
        width: 120px;
        height: 120px;
        background: linear-gradient(135deg, #DC2626 0%, #991B1B 100%);
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 70px;
        color: white;
        margin-bottom: -50px;
        z-index: 10;
        box-shadow: 0 12px 30px rgba(220, 38, 38, 0.5);
        line-height: 1;
    }

    .login-card {
        background: white;
        padding: 4rem 2.5rem 2.5rem 2.5rem;
        border-radius: 25px;
        width: 100%;
        max-width: 420px;
        box-shadow: 0 20px 60px rgba(0, 0, 0, 0.2);
    }

    .login-card h1 {
        text-align: center;
        margin: 1.5rem 0 0.5rem 0;
        font-size: 1.8rem;
        color: #2D1B69;
        font-weight: 700;
    }

    .login-card p {
        text-align: center;
        color: #999;
        font-size: 0.9rem;
        margin-bottom: 1.5rem;
    }

    .login-card form {
        width: 100%;
    }

    .form-field {
        margin-bottom: 1.5rem;
        position: relative;
    }

    .form-field input {
        width: 100%;
        padding: 12px 15px 12px 45px;
        border-radius: 12px;
        border: 1px solid #e0e0e0;
        background: #f5f5f5;
        color: #333;
        font-size: 1rem;
        box-sizing: border-box;
        transition: all 0.3s ease;
        font-family: 'Prompt', sans-serif;
    }

    .form-field input:focus {
        outline: none;
        border-color: #DC2626;
        background: #fff;
        box-shadow: 0 0 0 3px rgba(220, 38, 38, 0.1);
    }

    .form-field input::placeholder {
        color: #999;
    }

    .form-field i {
        position: absolute;
        left: 15px;
        top: 50%;
        transform: translateY(-50%);
        color: #999;
        font-size: 1.1rem;
    }

    .form-field small {
        color: #999;
        font-size: 0.8rem;
        margin-top: 5px;
        display: block;
    }

    .remember-me {
        margin-bottom: 1.5rem;
        display: flex;
        align-items: center;
        font-size: 0.9rem;
        color: #666;
    }

    .remember-me input {
        margin-right: 8px;
        width: 16px;
        height: 16px;
        cursor: pointer;
    }

    .remember-me label {
        cursor: pointer;
        margin: 0;
    }

    .login-card button {
        width: 100%;
        background: linear-gradient(135deg, #DC2626 0%, #991B1B 100%);
        color: white;
        border: none;
        padding: 14px 20px;
        border-radius: 12px;
        font-size: 1rem;
        font-weight: 600;
        cursor: pointer;
        transition: all 0.3s ease;
        box-shadow: 0 8px 20px rgba(220, 38, 38, 0.4);
        text-transform: uppercase;
        letter-spacing: 1px;
        font-family: 'Prompt', sans-serif;
    }

    .login-card button:hover {
        transform: translateY(-3px);
        box-shadow: 0 12px 30px rgba(220, 38, 38, 0.6);
        background: linear-gradient(135deg, #EF4444 0%, #DC2626 100%);
    }

    .login-card button:active {
        transform: translateY(-1px);
    }

    @media screen and (max-width: 600px) {
        .login-icon {
            width: 100px;
            height: 100px;
            font-size: 50px;
            margin-bottom: -40px;
        }

        .login-card {
            padding: 3rem 1.5rem 1.5rem 1.5rem;
            border-radius: 20px;
        }

        .login-card h1 {
            font-size: 1.5rem;
        }

        .login-card button {
            padding: 12px 18px;
            font-size: 0.9rem;
        }
    }
    </style>
</head>
<body>

    <div id="login-container">
        <div class="login-wrapper">
            <div class="login-icon">
                👤
            </div>
            <div class="login-card">
                <h1>ลงชื่อเข้าใช้</h1>
                <p>กรุณากรอกหมายเลขบัตรประชาชน 13 หลัก</p>
                <form onsubmit="return false;">
                    <div class="form-field">
                        <i class="fa fa-id-card"></i>
                        <input 
                            type="text" 
                            id="idCard" 
                            placeholder="เลขบัตรประชาชน 13 หลัก" 
                            maxlength="13"
                            pattern="[0-9]{13}"
                            inputmode="numeric"
                            required
                            oninput="formatIdCard(this)"
                        >
                        <small>กรอกตัวเลขเท่านั้น (ไม่ต้องใส่เครื่องหมาย -)</small>
                    </div>
                    <div class="remember-me">
                        <input type="checkbox" id="rememberMe">
                        <label for="rememberMe">จดจำฉันในระบบ</label>
                    </div>
                    <button type="button" onclick="handleLoginAttempt()">เข้าสู่ระบบ</button>
                </form>
            </div>
                <div style="text-align: center; color: rgba(255,255,255,0.6); font-size: 0.85rem; margin-top: 25px; font-weight: 300;">
                พัฒนาระบบโดย นายมนตรี ปัญญา <br>
                <span style="color: #FBBF24; font-weight: 500;">[ทีมงานขอบตาดำ]</span>
            </div>
        </div>
    </div>

    <script>
    function formatIdCard(input) {
        input.value = input.value.replace(/\D/g, '');
    }

    function validateIdCard(idCard) {
        if (!/^\d{13}$/.test(idCard)) {
            return false;
        }
        
        let sum = 0;
        for (let i = 0; i < 12; i++) {
            sum += parseInt(idCard.charAt(i)) * (13 - i);
        }
        const checkDigit = (11 - (sum % 11)) % 10;
        
        return checkDigit === parseInt(idCard.charAt(12));
    }

    function handleLoginAttempt() {
        const idCard = $('#idCard').val().trim();
        const remember = $('#rememberMe').is(':checked');

        if (!idCard || idCard.length !== 13) {
            Swal.fire({
                title: 'ข้อมูลไม่ถูกต้อง',
                text: 'กรุณากรอกหมายเลขบัตรประชาชน 13 หลัก',
                icon: 'warning',
                confirmButtonText: 'ตกลง'
            });
            return;
        }

        if (!/^\d{13}$/.test(idCard)) {
            Swal.fire({
                title: 'ข้อมูลไม่ถูกต้อง',
                text: 'กรุณากรอกเฉพาะตัวเลขเท่านั้น',
                icon: 'warning',
                confirmButtonText: 'ตกลง'
            });
            return;
        }

        if (!validateIdCard(idCard)) {
            Swal.fire({
                title: 'เลขบัตรประชาชนไม่ถูกต้อง',
                text: 'กรุณาตรวจสอบเลขบัตรประชาชนอีกครั้ง',
                icon: 'error',
                confirmButtonText: 'ตกลง'
            });
            return;
        }

        startloader("กำลังตรวจสอบสิทธิ์...");
        
        google.script.run
            .withSuccessHandler(function(output) {
                if (output) {
                    if (remember) {
                        localStorage.setItem('rememberedIdCard', idCard);
                    } else {
                        localStorage.removeItem('rememberedIdCard');
                    }
                    afterLoginSuccess(output);
                } else {
                    endloader();
                    Swal.fire({
                        title: 'ไม่พบข้อมูล',
                        text: 'ไม่พบหมายเลขบัตรประชาชนนี้ในระบบ',
                        icon: 'error',
                        confirmButtonText: 'ตกลง'
                    });
                }
            })
            .withFailureHandler(function(err){
                endloader();
                Swal.fire({
                    title: 'เกิดข้อผิดพลาด',
                    text: 'ไม่สามารถเชื่อมต่อเซิร์ฟเวอร์ได้',
                    icon: 'error',
                    confirmButtonText: 'ลองใหม่'
                });
            })
            .loginWithIdCard(idCard);
    }

    $('#idCard').on('keypress', function(e) {
        if (e.which === 13) {
            handleLoginAttempt();
        }
    });
    </script>
</body>
</html>
